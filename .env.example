# Event Configuration
EVENT_NAME="Build AI with Podman"
EVENT_API_ID="evt-sKdXrUlCLxEZSZg"

# Luma API (requires Luma Plus subscription)
LUMA_API_KEY=""

# Printer Configuration
PRINTER_MODEL="QL-820NWB"
LABEL_SIZE="62red"
# Leave empty for auto-detection, or specify like "usb://0x04f9:0x209d"
PRINTER_URI=""

# Server
HOST="0.0.0.0"
PORT=8000

# Approval status filter (comma-separated statuses to allow check-in)
# Only guests with these statuses appear on the check-in page.
# The admin dashboard always shows all guests regardless of this setting.
ALLOWED_STATUSES="approved"

# Auto-sync interval in seconds (how often to fetch new guests from Luma API)
SYNC_INTERVAL=300
